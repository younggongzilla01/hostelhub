generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  phone     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  hostel    Hostel?
}

model Hostel {
  id            String         @id @default(cuid())
  userId        String         @unique
  name          String
  address       String?
  city          String?
  state         String?
  pincode       String?
  phone         String?
  email         String?
  description   String?
  totalFloors   Int            @default(0)
  totalRooms    Int            @default(0)
  totalBeds     Int            @default(0)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  facilities    Facility[]
  sharingPrices SharingPrice[]
  floors        Floor[]
  students      Student[]
  oldStudents   OldStudent[]
  expenses      Expense[]
  visitors      Visitor[]
  complaints    Complaint[]
  maintenances  Maintenance[]
  notices       Notice[]
  invoices      Invoice[]
}

model Facility {
  id        String   @id @default(cuid())
  hostelId  String
  name      String
  icon      String?
  createdAt DateTime @default(now())
  hostel    Hostel   @relation(fields: [hostelId], references: [id], onDelete: Cascade)

  @@unique([hostelId, name])
}

model SharingPrice {
  id        String   @id @default(cuid())
  hostelId  String
  sharing   Int
  price     Float
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  hostel    Hostel   @relation(fields: [hostelId], references: [id], onDelete: Cascade)

  @@unique([hostelId, sharing])
}

model Floor {
  id        String   @id @default(cuid())
  hostelId  String
  number    Int
  name      String?
  createdAt DateTime @default(now())
  hostel    Hostel   @relation(fields: [hostelId], references: [id], onDelete: Cascade)
  rooms     Room[]

  @@unique([hostelId, number])
}

model Room {
  id        String   @id @default(cuid())
  floorId   String
  number    String
  sharing   Int      @default(2)
  totalBeds Int      @default(2)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  floor     Floor    @relation(fields: [floorId], references: [id], onDelete: Cascade)
  beds      Bed[]

  @@unique([floorId, number])
}

model Bed {
  id         String   @id @default(cuid())
  roomId     String
  number     Int
  isOccupied Boolean  @default(false)
  createdAt  DateTime @default(now())
  room       Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)
  student    Student?

  @@unique([roomId, number])
}

model Student {
  id             String    @id @default(cuid())
  hostelId       String
  bedId          String?   @unique
  name           String
  phone          String
  email          String?
  address        String?
  aadharNumber   String?
  idProofUrl     String?
  foodPreference String    @default("veg")
  monthlyRent    Float
  dueDate        Int       @default(5)
  joinDate       DateTime  @default(now())
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  hostel         Hostel    @relation(fields: [hostelId], references: [id], onDelete: Cascade)
  bed            Bed?      @relation(fields: [bedId], references: [id])
  payments       Payment[]

  @@index([hostelId, phone])
  @@index([hostelId, name])
}

model Payment {
  id          String   @id @default(cuid())
  studentId   String
  amount      Float
  paymentDate DateTime @default(now())
  month       String
  method      String   @default("cash")
  status      String   @default("paid")
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  student     Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId, month])
  @@index([studentId, status])
}

model OldStudent {
  id             String    @id @default(cuid())
  hostelId       String
  name           String
  phone          String
  email          String?
  address        String?
  aadharNumber   String?
  foodPreference String?
  roomNumber     String?
  monthlyRent    Float?
  totalPaid      Float     @default(0)
  joinDate       DateTime?
  leaveDate      DateTime  @default(now())
  createdAt      DateTime  @default(now())
  hostel         Hostel    @relation(fields: [hostelId], references: [id], onDelete: Cascade)

  @@index([hostelId, phone])
}

model Expense {
  id          String   @id @default(cuid())
  hostelId    String
  category    String
  description String
  amount      Float
  date        DateTime @default(now())
  createdAt   DateTime @default(now())
  hostel      Hostel   @relation(fields: [hostelId], references: [id], onDelete: Cascade)

  @@index([hostelId, category])
}

model Visitor {
  id        String    @id @default(cuid())
  hostelId  String
  studentId String?
  name      String
  phone     String?
  purpose   String
  inTime    DateTime  @default(now())
  outTime   DateTime?
  createdAt DateTime  @default(now())
  hostel    Hostel    @relation(fields: [hostelId], references: [id], onDelete: Cascade)

  @@index([hostelId, inTime])
}

model Complaint {
  id          String   @id @default(cuid())
  hostelId    String
  studentId   String?
  studentName String
  title       String
  description String
  status      String   @default("pending")
  priority    String   @default("normal")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  hostel      Hostel   @relation(fields: [hostelId], references: [id], onDelete: Cascade)

  @@index([hostelId, status])
}

model Maintenance {
  id          String   @id @default(cuid())
  hostelId    String
  roomNumber  String
  issue       String
  description String?
  status      String   @default("pending")
  priority    String   @default("normal")
  cost        Float?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  hostel      Hostel   @relation(fields: [hostelId], references: [id], onDelete: Cascade)

  @@index([hostelId, status])
}

model Notice {
  id         String    @id @default(cuid())
  hostelId   String
  title      String
  content    String
  priority   String    @default("normal")
  expiryDate DateTime?
  isActive   Boolean   @default(true)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  hostel     Hostel    @relation(fields: [hostelId], references: [id], onDelete: Cascade)

  @@index([hostelId, isActive])
}

model Invoice {
  id          String    @id @default(cuid())
  hostelId    String
  studentId   String?
  studentName String
  roomNumber  String?
  amount      Float
  month       String
  status      String    @default("pending")
  dueDate     DateTime?
  createdAt   DateTime  @default(now())
  hostel      Hostel    @relation(fields: [hostelId], references: [id], onDelete: Cascade)

  @@index([hostelId, status])
}
